[Unit]
Description=K20 Pro multimodal OpenAI-compatible bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/projects/k20-mm-bridge
EnvironmentFile=/root/projects/k20-mm-bridge/bridge.env
ExecStart=/usr/bin/python3 /root/projects/k20-mm-bridge/server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
